{
  "name": "@graviton711/claude-code-proxy",
  "version": "1.0.0",
  "description": "A proxy server that enables **Claude Code** to work with OpenAI-compatible API providers. Convert Claude API requests to OpenAI API calls, allowing you to use various LLM providers through the Claude Code CLI.",
  "main": "index.js",
  "bin": {
    "claude-proxy": "bin/cli.js"
  },
  "files": [
    "bin",
    "src",
    "requirements.txt",
    "pyproject.toml",
    "uv.lock",
    "start_proxy.py",
    "start_proxy_utf8.ps1",
    "docker-compose.yml",
    "Dockerfile",
    "README.md"
  ],
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/graviton711/claude_code_proxy.git"
  },
  "keywords": [],
